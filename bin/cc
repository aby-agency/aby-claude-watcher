#!/usr/bin/env bash
# cc — Claude Code wrapper that registers the session with Aby Claude Watcher
# Usage: cc [args...]

SOCKET_PATH="/tmp/aby-claude-watcher.sock"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
HOOK_PATH="$SCRIPT_DIR/aby-permission-hook.sh"

# Detect terminal app
detect_terminal() {
  if [ -n "$TERM_PROGRAM" ]; then
    echo "$TERM_PROGRAM"
  elif [ -n "$WT_SESSION" ]; then
    echo "WindowsTerminal"
  else
    echo "unknown"
  fi
}

# Detect terminal identifier (tab/pane ID)
detect_terminal_id() {
  if [ -n "$ITERM_SESSION_ID" ]; then
    echo "$ITERM_SESSION_ID"
  elif [ -n "$WARP_SESSION_ID" ]; then
    echo "$WARP_SESSION_ID"
  elif [ -n "$WT_SESSION" ]; then
    echo "$WT_SESSION"
  else
    echo "$$"
  fi
}

# Send message to Aby Claude Watcher via socket (async, non-blocking)
# Tries nc -U first, falls back to python3 if unavailable
notify_claude_watch() {
  local msg="$1"
  if [ ! -S "$SOCKET_PATH" ]; then return; fi
  if echo "" | nc -U -w 1 "$SOCKET_PATH" >/dev/null 2>&1; then
    echo "$msg" | nc -U -w 1 "$SOCKET_PATH" 2>/dev/null &
  elif command -v python3 >/dev/null 2>&1; then
    python3 -c "
import socket, sys
s = socket.socket(socket.AF_UNIX)
s.settimeout(1)
try:
    s.connect(sys.argv[1])
    s.sendall((sys.argv[2] + '\n').encode())
except: pass
finally: s.close()
" "$SOCKET_PATH" "$msg" &
  fi
}

# Idempotently ensure the permission-detection hooks are installed in the
# project-local .claude/settings.local.json. Never overwrites other user hooks.
install_hooks() {
  if [ ! -x "$HOOK_PATH" ]; then return; fi
  if ! command -v python3 >/dev/null 2>&1; then return; fi
  # $HOME/.claude/settings.local.json is the global Claude Code user config.
  # Installing there is fine — it covers sessions started outside of a project.
  mkdir -p .claude 2>/dev/null || return
  local settings=".claude/settings.local.json"
  python3 - "$settings" "$HOOK_PATH" <<'PY' 2>/dev/null
import json, os, sys
path, hook_path = sys.argv[1], sys.argv[2]
HOOK_FILENAME = os.path.basename(hook_path)
data = {}
if os.path.exists(path):
    try:
        with open(path) as f:
            data = json.load(f)
    except Exception:
        # Don't clobber user data if parsing fails.
        sys.exit(0)
    if not isinstance(data, dict):
        sys.exit(0)
hooks = data.get('hooks')
if not isinstance(hooks, dict):
    hooks = {}
    data['hooks'] = hooks
changed = False

def is_ours(block):
    if not isinstance(block, dict):
        return False
    for h in (block.get('hooks') or []):
        if isinstance(h, dict) and isinstance(h.get('command'), str) and h['command'].endswith('/' + HOOK_FILENAME):
            return True
    return False

for event in ('PreToolUse', 'Notification'):
    entries = hooks.get(event)
    if not isinstance(entries, list):
        entries = []
        hooks[event] = entries
    found = False
    for block in entries:
        if is_ours(block):
            found = True
            # Self-heal: refresh the command path if the app was relocated.
            for h in (block.get('hooks') or []):
                if isinstance(h, dict) and h.get('command') != hook_path:
                    h['command'] = hook_path
                    changed = True
            break
    if not found:
        entries.append({
            'matcher': '*' if event == 'PreToolUse' else '',
            'hooks': [{'type': 'command', 'command': hook_path}],
        })
        changed = True
if changed:
    with open(path, 'w') as f:
        json.dump(data, f, indent=2)
        f.write('\n')
PY
}

TERMINAL_APP=$(detect_terminal)
TERMINAL_ID=$(detect_terminal_id)

# Ensure the permission hooks are in place for this project (cheap, idempotent)
install_hooks

# Notify Aby Claude Watcher in the background BEFORE launching Claude
# We use $$ (our PID) — the watcher will find the session via the sessions dir
notify_claude_watch "{\"action\":\"register\",\"pid\":$$,\"terminalApp\":\"$TERMINAL_APP\",\"terminalId\":\"$TERMINAL_ID\",\"cwd\":\"$(pwd)\"}"

# Launch Claude Code in the foreground (interactive — needs stdin/stdout)
exec claude "$@"

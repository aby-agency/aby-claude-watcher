#!/usr/bin/env bash
# cwa — Attach current terminal to an active Claude Code session in Claude Watch
# Usage: cwa [session_id]

SOCKET_PATH="/tmp/claude-watch.sock"
SESSIONS_DIR="$HOME/.claude/sessions"

detect_terminal() {
  if [ -n "$TERM_PROGRAM" ]; then
    echo "$TERM_PROGRAM"
  elif [ -n "$WT_SESSION" ]; then
    echo "WindowsTerminal"
  else
    echo "unknown"
  fi
}

detect_terminal_id() {
  if [ -n "$ITERM_SESSION_ID" ]; then
    echo "$ITERM_SESSION_ID"
  elif [ -n "$WARP_SESSION_ID" ]; then
    echo "$WARP_SESSION_ID"
  elif [ -n "$WT_SESSION" ]; then
    echo "$WT_SESSION"
  else
    echo "$$"
  fi
}

notify_claude_watch() {
  local msg="$1"
  if [ ! -S "$SOCKET_PATH" ]; then return; fi
  if echo "" | nc -U -w 1 "$SOCKET_PATH" >/dev/null 2>&1; then
    echo "$msg" | nc -U -w 1 "$SOCKET_PATH" 2>/dev/null || true
  elif command -v python3 >/dev/null 2>&1; then
    python3 -c "
import socket, sys
s = socket.socket(socket.AF_UNIX)
s.settimeout(1)
try:
    s.connect(sys.argv[1])
    s.sendall((sys.argv[2] + '\n').encode())
except: pass
finally: s.close()
" "$SOCKET_PATH" "$msg" || true
  fi
}

TERMINAL_APP=$(detect_terminal)
TERMINAL_ID=$(detect_terminal_id)

# If session ID provided as argument
if [ -n "$1" ]; then
  SESSION_ID="$1"
  notify_claude_watch "{\"action\":\"attach\",\"sessionId\":\"$SESSION_ID\",\"terminalApp\":\"$TERMINAL_APP\",\"terminalId\":\"$TERMINAL_ID\"}"
  echo "Attached session $SESSION_ID to Claude Watch"
  exit 0
fi

# Auto-detect: find active sessions
if [ ! -d "$SESSIONS_DIR" ]; then
  echo "No Claude Code sessions directory found."
  exit 1
fi

read_json_field() {
  local file="$1"
  local field="$2"
  if command -v jq >/dev/null 2>&1; then
    jq -r ".$field" "$file" 2>/dev/null
  elif command -v python3 >/dev/null 2>&1; then
    python3 -c "import json,sys; print(json.load(open(sys.argv[1]))[sys.argv[2]])" "$file" "$field" 2>/dev/null
  elif command -v node >/dev/null 2>&1; then
    node -e "console.log(JSON.parse(require('fs').readFileSync(process.argv[1]))[process.argv[2]])" "$file" "$field" 2>/dev/null
  fi
}

ACTIVE_SESSIONS=()
for f in "$SESSIONS_DIR"/*.json; do
  [ -f "$f" ] || continue
  PID=$(read_json_field "$f" "pid")
  SESSION_ID=$(read_json_field "$f" "sessionId")
  if [ -n "$PID" ] && kill -0 "$PID" 2>/dev/null; then
    ACTIVE_SESSIONS+=("$SESSION_ID|$PID|$f")
  fi
done

if [ ${#ACTIVE_SESSIONS[@]} -eq 0 ]; then
  echo "No active Claude Code sessions found."
  exit 1
fi

if [ ${#ACTIVE_SESSIONS[@]} -eq 1 ]; then
  SESSION_ID=$(echo "${ACTIVE_SESSIONS[0]}" | cut -d'|' -f1)
  notify_claude_watch "{\"action\":\"attach\",\"sessionId\":\"$SESSION_ID\",\"terminalApp\":\"$TERMINAL_APP\",\"terminalId\":\"$TERMINAL_ID\"}"
  echo "Attached session $SESSION_ID to Claude Watch"
  exit 0
fi

# Multiple sessions — let user choose
echo "Multiple active sessions found:"
i=1
for entry in "${ACTIVE_SESSIONS[@]}"; do
  SID=$(echo "$entry" | cut -d'|' -f1)
  SPID=$(echo "$entry" | cut -d'|' -f2)
  echo "  [$i] $SID (PID: $SPID)"
  i=$((i+1))
done

printf "Select session [1-%d]: " ${#ACTIVE_SESSIONS[@]}
read -r choice

if [[ "$choice" =~ ^[0-9]+$ ]] && [ "$choice" -ge 1 ] && [ "$choice" -le ${#ACTIVE_SESSIONS[@]} ]; then
  idx=$((choice - 1))
  SESSION_ID=$(echo "${ACTIVE_SESSIONS[$idx]}" | cut -d'|' -f1)
  notify_claude_watch "{\"action\":\"attach\",\"sessionId\":\"$SESSION_ID\",\"terminalApp\":\"$TERMINAL_APP\",\"terminalId\":\"$TERMINAL_ID\"}"
  echo "Attached session $SESSION_ID to Claude Watch"
else
  echo "Invalid choice."
  exit 1
fi

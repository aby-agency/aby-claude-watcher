{
  "name": "claude-watch",
  "version": "1.0.0",
  "description": "Dashboard desktop pour monitorer en temps réel vos sessions Claude Code",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder --mac",
    "test": "node test/url.test.js && node test/focus.test.js && node test/config.test.js"
  },
  "build": {
    "appId": "com.claudewatch.app",
    "productName": "Claude Watch",
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": ["dmg"],
      "icon": "assets/icon.svg"
    },
    "dmg": {
      "title": "Claude Watch"
    },
    "files": [
      "main.js",
      "preload.js",
      "watcher.js",
      "socket.js",
      "focus.js",
      "config.js",
      "ui/**/*",
      "bin/**/*",
      "assets/**/*"
    ]
  },
  "bin": {
    "claude-watch": "main.js"
  },
  "keywords": [
    "claude",
    "code",
    "monitor",
    "electron",
    "dashboard"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1"
  }
}
